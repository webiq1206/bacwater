# --- Database ---
# Dev default: SQLite. For production on Replit/Postgres, override with the Postgres URL.
DATABASE_URL="file:./prisma/dev.db"

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="BACWater.ai"

# --- Auth ---
AUTH_SECRET="replace-me-with-a-32-char-random-string"
AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Email ---
RESEND_API_KEY=""
RESEND_FROM="BACWater.ai <orders@bacwater.ai>"

# --- AI Assistant ---
# The assistant only explains numbers already computed by the deterministic
# math library — it never does the math itself. Haiku is more than enough
# for this workload and keeps API costs low. Bump to sonnet-4-6 if answers
# feel thin; only reach for opus-4-8 if you truly need it.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# --- Admin bootstrap ---
# comma-separated list of emails granted the admin role automatically on signup
ADMIN_EMAILS="info@webiq.co"
