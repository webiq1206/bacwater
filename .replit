modules = ["nodejs-22", "postgresql-16"]
hidden = [".config", ".next", "node_modules"]

run = "npm run dev"

[nix]
channel = "stable-24_05"

[deployment]
build = ["sh", "-c", "npm install --include=dev && npx prisma generate && npx prisma db push --skip-generate --accept-data-loss && npm run build"]
run = ["sh", "-c", "npm start"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 3000
externalPort = 80

